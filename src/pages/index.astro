---
import BaseLayout from '../layouts/BaseLayout.astro';
import PersonaCard from '../components/PersonaCard.astro';
import BuilderSvg from '../components/BuilderSvg.astro';
import CraftsmanSvg from '../components/CraftsmanSvg.astro';
---
<BaseLayout title="Choose Your Path">
  <div class="text-center mb-10">
    <h1 class="text-4xl font-bold text-white mb-3">
      Welcome to Agentic Onboarding
    </h1>
    <p class="text-lg text-slate-400 max-w-lg mx-auto">
      Learn to build with Claude Code. Pick the persona that fits you best.
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-6">
    <PersonaCard
      name="The Builder"
      tagline="Curious, hands-on, ready to tinker"
      bullets={[
        'Picks up new tools and runs with them',
        'Finds broken things interesting, not frustrating',
        'Wants depth, control, and understanding',
        'Comfortable with the terminal',
      ]}
      href={`${import.meta.env.BASE_URL}builder/platform`}
      available={true}
    >
      <BuilderSvg slot="illustration" />
    </PersonaCard>

    <PersonaCard
      name="The Craftsman"
      tagline="Earned every line. Evaluates every tool."
      bullets={[
        'Years of mastery — values quality over speed',
        'Evaluates tools by what they cost, not just what they promise',
        'Wants control, transparency, and the ability to verify',
        'Looking for a force multiplier, not an autopilot',
      ]}
      href={`${import.meta.env.BASE_URL}craftsman/why`}
      available={true}
    >
      <CraftsmanSvg slot="illustration" />
    </PersonaCard>
  </div>
</BaseLayout>
