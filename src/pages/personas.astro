---
import BaseLayout from '../layouts/BaseLayout.astro';

type Trait = { name: string; tier: 'I' | 'II' | 'III'; note: string; sources: number[] };
type Subclass = { name: string; glyph: string; tagline: string; sources: number[]; traits: Trait[] };
type Stats = { craft: number; vision: number; poise: number; voice: number; edge: number };
type ClassKey = 'builder' | 'craftsman' | 'navigator' | 'strategist';
type BaseClass = {
  key: ClassKey;
  name: string;
  glyph: string;
  tagline: string;
  flavor: string;
  stats: Stats;
  sources: number[];
  subclasses: Subclass[];
};

