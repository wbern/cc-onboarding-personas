  navigator:  { stroke: '#38bdf8', fill: '#0a1620', tint: 'rgba(56,189,248,0.18)', text: '#bae6fd', dim: 'rgba(56,189,248,0.45)', deep: '#0c4a6e' },
  strategist: { stroke: '#a78bfa', fill: '#130b22', tint: 'rgba(167,139,250,0.18)', text: '#ddd6fe', dim: 'rgba(167,139,250,0.45)', deep: '#4c1d95' },
