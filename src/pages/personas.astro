---
<BaseLayout title="Persona Skill Tree (v0)" noindex={true}>
  <div class="w-full max-w-[1900px] mx-auto">
    <header class="text-center mb-8 max-w-4xl mx-auto px-4 relative">
      <div class="hero-banner relative inline-block px-12 py-5">
        <span class="banner-flourish banner-flourish-l" aria-hidden="true"></span>
        <span class="banner-flourish banner-flourish-r" aria-hidden="true"></span>
        <div class="text-[10px] tracking-[0.55em] uppercase text-amber-200/70 mb-2">⚜ The Codex of Practice ⚜</div>
        <h1 class="text-4xl md:text-6xl font-black text-white tracking-tight font-display leading-none">Persona Skill Tree</h1>
        <div class="text-[10px] tracking-[0.4em] uppercase text-slate-400 mt-2">v0 · evidence-annotated</div>
      </div>
      <p class="text-slate-400 leading-relaxed text-sm mt-5 max-w-2xl mx-auto">
        Four classes, twelve specializations, thirty-six leveled skills. Hover a trait
        to see its read-out, sources, and any cross-class synergy.
      </p>
    </header>

    <!-- Mobile-only class tab nav -->
    <nav class="lg:hidden mb-4 mx-4 flex items-center justify-between gap-2 rounded-xl border border-slate-700 bg-slate-900/60 p-2" aria-label="Class navigation">
      {tree.map((cls, i) => {
        const c = colorOf[cls.key];
        return (
          <button
            type="button"
            class="class-tab flex-1 rounded-md px-2 py-1.5 text-[10px] font-bold tracking-[0.18em] uppercase text-center transition"
            data-tab-target={cls.key}
            data-tab-idx={i}
            style={`color: ${c.text}; background: rgba(2,6,23,0.6); box-shadow: 0 0 0 1px ${c.dim} inset`}
          >
            <span class="mr-1" aria-hidden="true" style="font-family: Georgia, serif">{cls.glyph}</span>
            {cls.name}
          </button>
        );
      })}
    </nav>

    <!-- Skill tree: flex carousel on small, grid on lg+ -->
    <div class="tree-wrap relative">
      <!-- Cross-class arc overlay (desktop only) -->
      <svg id="cross-arcs" class="hidden lg:block absolute inset-0 pointer-events-none z-30" width="100%" height="100%" aria-hidden="true" style="overflow: visible;">
        <defs>
          {(['builder', 'craftsman', 'navigator', 'strategist'] as const).map((aKey) =>
            (['builder', 'craftsman', 'navigator', 'strategist'] as const).map((bKey) => (
              <linearGradient id={`grad-${aKey}-${bKey}`} x1="0" x2="1" y1="0" y2="0">
                <stop offset="0%" stop-color={colorOf[aKey].stroke} stop-opacity="0.9" />
                <stop offset="100%" stop-color={colorOf[bKey].stroke} stop-opacity="0.9" />
              </linearGradient>
            ))
          )}
        </defs>
      </svg>
      <div
        class="flex overflow-x-auto snap-x snap-mandatory gap-4 -mx-4 px-4 pb-4
               lg:grid lg:grid-cols-4 lg:gap-10 lg:overflow-visible lg:snap-none lg:mx-0 lg:px-6 relative z-10"
      >
        {tree.map((cls, ci) => {
          const c = colorOf[cls.key];
          // Stagger class columns vertically — break the grid feel
          const colOffsets = [0, 28, 12, 36];
          const colOffset = colOffsets[ci] ?? 0;
          return (
            <div
              class="snap-center shrink-0 w-[calc(100vw-2rem)] lg:w-auto lg:shrink class-tree lg:translate-y-[var(--col-offset)]"
              data-cls-key={cls.key}
              style={`--col-offset: ${colOffset}px`}
            >
              <!-- CLASS CARD -->
              <div
                class={`skill-node class-card cls-${cls.key} relative rounded-xl border-2 p-4 cursor-help group`}
                tabindex="0"
                data-cls={cls.key}
                data-tip-kind="class"
                data-tip={JSON.stringify({ name: `The ${cls.name}`, tagline: cls.tagline, flavor: cls.flavor, sources: cls.sources })}
                style={`border-color: ${c.stroke}; background: linear-gradient(165deg, ${c.tint} 0%, ${c.fill} 75%, transparent 100%); box-shadow: 0 0 0 1px ${c.dim} inset, 0 6px 20px -6px ${c.dim}`}
              >
                <!-- Corner ornaments -->
                <span aria-hidden="true" class="corner-orn corner-tl" style={`color: ${c.stroke}`}></span>
                <span aria-hidden="true" class="corner-orn corner-tr" style={`color: ${c.stroke}`}></span>
                <span aria-hidden="true" class="corner-orn corner-bl" style={`color: ${c.stroke}`}></span>
                <span aria-hidden="true" class="corner-orn corner-br" style={`color: ${c.stroke}`}></span>
                <div class="absolute -top-2 left-3 px-2 py-0.5 text-[9px] tracking-[0.35em] font-bold rounded uppercase" style={`background: ${c.deep}; color: ${c.text}; box-shadow: 0 0 0 1px ${c.dim}`}>Class</div>
                <div class="flex items-start gap-3">
                  <div class="text-5xl leading-none" style={`color: ${c.text}; font-family: Georgia, serif; text-shadow: 0 0 12px ${c.dim}`}>{cls.glyph}</div>
                  <div class="flex-1 min-w-0">
                    <div class="text-2xl font-black tracking-tight text-white uppercase font-display leading-none mt-1">{cls.name}</div>
                    <div class="text-[10px] text-slate-400 italic mt-1.5 leading-tight">{cls.tagline}</div>
                  </div>
                </div>
              </div>

              <!-- Visual stem from class to subclasses -->
              <div class="flex justify-around px-4 mt-5">
                {cls.subclasses.map(() => (
                  <div class="w-px h-6" style={`background: linear-gradient(180deg, ${c.stroke}, ${c.dim})`}></div>
                ))}
              </div>

              <!-- SUBCLASS COLUMNS -->
              <div class="grid grid-cols-3 gap-3">
                {cls.subclasses.map((sub, si) => {
                  // Stagger subclass branches — middle column dips, edges lift
                  const subOffsets = [0, 18, 6];
                  const subOffset = subOffsets[si] ?? 0;
                  return (
                    <div class="flex flex-col gap-3" style={`transform: translateY(${subOffset}px)`}>
                      <!-- SUBCLASS CARD -->
                      <div
                        class={`skill-node subclass-card cls-${cls.key} relative rounded-lg border p-3 cursor-help`}
                        tabindex="0"
                        data-cls={cls.key}
                        data-sub-id={`${cls.key}.${si}`}
                        data-tip-kind="subclass"
                        data-tip={JSON.stringify({ name: sub.name, tagline: sub.tagline, sources: sub.sources })}
                        style={`border-color: ${c.dim}; background: linear-gradient(180deg, ${c.fill}, rgba(2,6,23,0.7))`}
                      >
                        <div class="flex flex-col items-center gap-1.5 text-center">
                          <span class="text-2xl leading-none" style={`color: ${c.text}; font-family: Georgia, serif; text-shadow: 0 0 10px ${c.dim}`}>{sub.glyph}</span>
                          <span class="font-display text-[12px] font-bold tracking-[0.08em] text-white uppercase">{sub.name}</span>
                        </div>
                      </div>

                      <!-- Stem to traits -->
                      <div class="flex justify-center">
                        <div class="w-px h-4" style={`background: ${c.dim}`}></div>
                      </div>

                      <!-- TRAIT CARDS -->
                      {sub.traits.map((trait, ti) => {
                        const cur = curFor(cls.key, ti);
                        const max = maxFor(cls.key, ti);
                        const traitId = `${cls.key}.${si}.${ti}`;
                        const strength = cur >= 7 ? 'strong' : cur >= 4 ? 'active' : cur >= 1 ? 'faint' : 'passive';
                        const borderRgba =
                          strength === 'strong' ? `${c.stroke}` :
                          strength === 'active' ? `${c.dim}` :
                          strength === 'faint'  ? `${c.dim}66` :
                                                  `rgba(148,163,184,0.35)`;
                        const cardStyle =
                          strength === 'strong'
                            ? `--card-border: ${c.stroke}cc; background: linear-gradient(180deg, ${c.tint}, rgba(2,6,23,0.95)); box-shadow: 0 0 18px -2px ${c.stroke}66, 0 4px 14px -6px ${c.stroke}`
                            : strength === 'active'
                            ? `--card-border: ${borderRgba}; background: linear-gradient(180deg, rgba(2,6,23,0.55), rgba(2,6,23,0.95)); box-shadow: 0 0 8px -3px ${c.dim}`
                            : strength === 'faint'
                            ? `--card-border: ${borderRgba}; background: linear-gradient(180deg, rgba(2,6,23,0.7), rgba(2,6,23,0.95)); filter: saturate(0.7)`
                            : `--card-border: ${borderRgba}; background: linear-gradient(180deg, rgba(15,23,42,0.6), rgba(2,6,23,0.85)); filter: saturate(0.25)`;
                        return (
                          <div
                            class={`skill-node trait-card cls-${cls.key} trait-${strength} relative cursor-help`}
                            tabindex="0"
                            data-cls={cls.key}
                            data-trait-id={traitId}
                            data-tip-kind="trait"
                            data-tip={JSON.stringify({ name: trait.name, tier: trait.tier, note: trait.note, sources: trait.sources, level: cur, max })}
                            style={cardStyle}
                          >
                            <div class="flex flex-col items-center text-center px-2 pt-3.5 pb-3 gap-1.5">
                              <span class="trait-glyph leading-none" style={`color: ${strength === 'passive' ? '#cbd5e1' : c.text}; font-family: Georgia, serif; ${strength === 'strong' ? `text-shadow: 0 0 16px ${c.stroke}, 0 0 6px ${c.dim}` : strength === 'active' ? `text-shadow: 0 0 8px ${c.dim}` : ''}`}>{trait.glyph}</span>
                              <span class={`font-display text-[11px] font-semibold tracking-[0.05em] leading-tight uppercase ${strength === 'passive' ? 'text-slate-300' : 'text-white'}`}>{trait.name}</span>
                            </div>
                            <span class="trait-lv font-display" style={`color: ${strength === 'passive' ? '#94a3b8' : c.text}; background: ${strength === 'passive' ? 'rgba(30,41,59,0.85)' : `${c.deep}cc`}; box-shadow: 0 0 0 1px ${strength === 'passive' ? 'rgba(148,163,184,0.3)' : c.dim}${strength === 'strong' ? `, 0 0 8px -1px ${c.stroke}` : ''}`}>LV {cur}</span>
                          </div>
                        );
                      })}
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>

      <!-- Cross-class link payload for JS arc renderer -->
      <script id="cross-link-data" type="application/json" set:html={JSON.stringify(crossLinks)}></script>

      <!-- Mobile-only cross-link list (arcs hidden below lg) -->
      <section class="lg:hidden mt-6 mx-4 rounded-xl border border-slate-700 bg-slate-900/40 p-4">
        <h3 class="text-[10px] tracking-[0.3em] uppercase text-slate-400 mb-3 text-center">Cross-class synergies</h3>
        <div class="grid grid-cols-1 gap-2 text-xs">
          {crossLinks.map((link) => {
            const [aCls] = link.from.split('.');
            const [bCls] = link.to.split('.');
            const ca = colorOf[aCls as ClassKey];
            const cb = colorOf[bCls as ClassKey];
            return (
              <div class="flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-2">
                <span class="w-2 h-2 rounded-full" style={`background: ${ca.stroke}; box-shadow: 0 0 6px ${ca.stroke}`}></span>
                <span class="text-slate-300 italic flex-1">{link.label}</span>
                <span class="w-2 h-2 rounded-full" style={`background: ${cb.stroke}; box-shadow: 0 0 6px ${cb.stroke}`}></span>
              </div>
            );
          })}
        </div>
      </section>
    </div>

    <!-- Tooltip overlay -->
    <div id="skill-tooltip" class="skill-tt fixed z-50 opacity-0 transition-opacity duration-150 pointer-events-none" style="left:0;top:0"></div>

    <!-- Sources -->
    <section class="mt-12 pt-8 border-t border-slate-800 max-w-6xl mx-auto px-4">
      <div class="flex items-baseline justify-between flex-wrap gap-3 mb-4">
        <h2 class="text-sm font-semibold text-slate-200 uppercase tracking-wide">Sources ({sources.length})</h2>
        <div class="flex gap-2 flex-wrap text-[10px] uppercase tracking-wider">
          <span class="px-2 py-0.5 rounded border bg-emerald-500/15 text-emerald-200 border-emerald-500/30">meta-analysis / review</span>
          <span class="px-2 py-0.5 rounded border bg-sky-500/15 text-sky-200 border-sky-500/30">empirical / ethnography</span>
          <span class="px-2 py-0.5 rounded border bg-violet-500/15 text-violet-200 border-violet-500/30">theory</span>
          <span class="px-2 py-0.5 rounded border bg-slate-700/40 text-slate-300 border-slate-600/40">book / essay</span>
        </div>
      </div>
      <ol class="text-xs text-slate-400 space-y-2 leading-relaxed columns-1 md:columns-2 gap-x-8">
        {sources.map((s) => (
          <li class="break-inside-avoid">
            <span class="text-slate-500 font-mono mr-1">[{s.id}]</span>
            <span class={`inline-block text-[9px] uppercase tracking-wider px-1.5 py-0.5 mr-1.5 rounded border ${kindColor[s.kind] ?? kindColor['book']}`}>{s.kind}</span>
            {s.cite}
          </li>
        ))}
      </ol>
    </section>

    <!-- Limitations -->
    <section class="mt-12 max-w-3xl mx-auto px-4 rounded-xl border border-slate-700/70 bg-slate-900/40 p-5 text-sm text-slate-300 leading-relaxed mb-12">
      <h2 class="text-sm font-semibold text-slate-200 uppercase tracking-wide mb-3">Limitations &amp; open questions</h2>
      <ul class="space-y-2 list-disc pl-5">
        <li><strong class="text-white">Levels are illustrative.</strong> The 1-10 values per trait reflect a stylized "progression profile" per class, not psychometric measurements.</li>
        <li><strong class="text-white">Builder vs. Craftsman overlap.</strong> Tinkerer and Purist both prize hands-on engagement. Holland’s Realistic type<sup>3</sup> covers both; the split here is cultural (maker vs. guild).</li>
        <li><strong class="text-white">Strategist as type vs. mode.</strong> Mintzberg<sup>45,46</sup> and Simon<sup>47</sup> describe strategic <em>thinking</em>, which any persona can adopt situationally.</li>
        <li><strong class="text-white">Deliberate-practice caveat.</strong> The Craftsman base leans on Ericsson<sup>23</sup>, but Macnamara et al. 2014<sup>24</sup> shows practice explains less variance than originally claimed.</li>
        <li><strong class="text-white">Software-engineer personality data is thin.</strong> Cruz, da Silva &amp; Capretz<sup>59</sup> map 40 years of research and find most studies use the contested MBTI instrument.</li>
        <li><strong class="text-white">AI-pair-programming traits are extrapolation.</strong> They draw on the cited literature but are not direct empirical findings about working with AI assistants.</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;900&family=Inter:wght@400;500;600;700;900&display=swap');

  :global(body) {
    background:
      radial-gradient(ellipse at 20% 0%, rgba(251,191,36,0.05), transparent 50%),
      radial-gradient(ellipse at 50% 0%, rgba(52,211,153,0.04), transparent 50%),
      radial-gradient(ellipse at 80% 0%, rgba(167,139,250,0.05), transparent 50%),
      radial-gradient(ellipse at 50% 100%, rgba(56,189,248,0.04), transparent 50%),
      #0a0e1a;
  }

  .font-display {
    font-family: 'Cinzel', Georgia, serif;
  }

  .skill-node {
    cursor: pointer;
    transition: all 200ms ease;
    outline: none;
  }
  .trait-glyph {
    font-size: 30px;
    display: block;
    line-height: 1;
  }

  /* Trait cards: uniform clean border, no per-card variation */
  .trait-card {
    border: 1px solid var(--card-border, rgba(148,163,184,0.4));
    border-radius: 10px;
  }

  /* Dog-ear level badge in bottom-right of trait card */
  .trait-lv {
    position: absolute;
    bottom: 0;
    right: 0;
    padding: 2px 7px 2px 8px;
    font-size: 9px;
    letter-spacing: 0.18em;
    font-weight: 700;
    border-top-left-radius: 6px;
    border-bottom-right-radius: 7px;
    line-height: 1.4;
  }
  .skill-node:hover,
  .skill-node:focus {
    transform: translateY(-1px);
    filter: brightness(1.15);
  }
  .skill-node.class-card:hover,
  .skill-node.class-card:focus {
    transform: translateY(-2px);
  }

  /* Cross-link partner highlight (set by JS on hover) */
  .trait-card.is-cross-target {
    transform: translateY(-2px);
    filter: brightness(1.35);
  }
  .trait-card.is-cross-target::after {
    content: '↔';
    position: absolute;
    top: -10px;
    right: -8px;
    width: 18px; height: 18px;
    border-radius: 999px;
    background: rgba(2,6,23,0.95);
    border: 1px solid currentColor;
    color: var(--c-cross, #fde68a);
    font-size: 11px;
    line-height: 16px;
    text-align: center;
    box-shadow: 0 0 8px currentColor;
  }
  .trait-card.cls-builder.is-cross-target    { --c-cross: #fde68a; }
  .trait-card.cls-craftsman.is-cross-target  { --c-cross: #a7f3d0; }
  .trait-card.cls-navigator.is-cross-target  { --c-cross: #bae6fd; }
  .trait-card.cls-strategist.is-cross-target { --c-cross: #ddd6fe; }

  /* Hover overrides on faint/passive — restore presence */
  .trait-card.trait-faint:hover,
  .trait-card.trait-faint:focus {
    filter: saturate(1) brightness(1.15);
  }
  .trait-card.trait-passive:hover,
  .trait-card.trait-passive:focus {
    filter: saturate(0.8) brightness(1.2);
  }

  .skill-tt {
    transition: opacity 150ms ease;
  }
  .skill-tt.show {
    opacity: 1;
  }

  /* Mobile carousel */
  .tree-wrap > div::-webkit-scrollbar {
    display: none;
  }
  .tree-wrap > div {
    scrollbar-width: none;
  }
  .class-tree {
    scroll-snap-stop: always;
  }
  .class-tab {
    transition: filter 150ms ease, transform 150ms ease;
  }
  .class-tab.is-active {
    filter: brightness(1.4);
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px currentColor inset,
      0 0 12px -2px currentColor !important;
  }

  /* Hero banner ornaments */
  .hero-banner {
    border-top: 1px solid rgba(251, 191, 36, 0.25);
    border-bottom: 1px solid rgba(251, 191, 36, 0.25);
  }
  .hero-banner::before,
  .hero-banner::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(251,191,36,0.5) 30%, rgba(251,191,36,0.5) 70%, transparent);
  }
  .hero-banner::before { top: 4px; }
  .hero-banner::after  { bottom: 4px; }
  .banner-flourish {
    position: absolute;
    top: 50%;
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(251,191,36,0.6));
  }
  .banner-flourish::before {
    content: '◆';
    position: absolute;
    top: -7px;
    color: rgba(251,191,36,0.85);
    font-size: 10px;
    text-shadow: 0 0 8px rgba(251,191,36,0.6);
  }
  .banner-flourish-l { left: -40px; }
  .banner-flourish-l::before { right: -8px; }
  .banner-flourish-r { right: -40px; transform: scaleX(-1); }
  .banner-flourish-r::before { right: -8px; }

  /* Class-card corner ornaments — small angle brackets */
  .corner-orn {
    position: absolute;
    width: 14px;
    height: 14px;
    pointer-events: none;
    opacity: 0.85;
  }
  .corner-orn::before,
  .corner-orn::after {
    content: '';
    position: absolute;
    background: currentColor;
    box-shadow: 0 0 4px currentColor;
  }
  .corner-orn::before { width: 14px; height: 1px; }
  .corner-orn::after  { width: 1px;  height: 14px; }
  .corner-tl { top: 4px;    left: 4px; }
  .corner-tl::before { top: 0; left: 0; }
  .corner-tl::after  { top: 0; left: 0; }
  .corner-tr { top: 4px;    right: 4px; }
  .corner-tr::before { top: 0; right: 0; }
  .corner-tr::after  { top: 0; right: 0; }
  .corner-bl { bottom: 4px; left: 4px; }
  .corner-bl::before { bottom: 0; left: 0; }
  .corner-bl::after  { bottom: 0; left: 0; }
  .corner-br { bottom: 4px; right: 4px; }
  .corner-br::before { bottom: 0; right: 0; }
  .corner-br::after  { bottom: 0; right: 0; }
</style>

<script>
  type TipKind = 'class' | 'subclass' | 'trait';
  const colorMap: Record<string, string> = {
    'cls-builder':    '#fbbf24',
    'cls-craftsman':  '#34d399',
    'cls-navigator':  '#38bdf8',
    'cls-strategist': '#a78bfa',
  };
  function colorFor(node: Element): string {
    for (const cls of Array.from(node.classList)) {
      if (colorMap[cls]) return colorMap[cls];
    }
    return '#fff';
  }

  const tip = document.getElementById('skill-tooltip')!;

  function render(kind: TipKind, p: any, color: string): string {
    const borderStyle = `border-color:${color}66;box-shadow:0 0 30px -8px ${color}99,0 0 0 1px rgba(0,0,0,0.6) inset`;
    if (kind === 'class') {
      return `
        <div class="rounded-lg border bg-slate-950/95 p-3.5 shadow-2xl text-left w-72" style="${borderStyle}">
          <div class="text-base font-bold mb-1" style="color:${color}">${p.name}</div>
          <div class="text-xs italic text-slate-300 mb-2">${p.tagline}</div>
          <div class="text-xs text-slate-400 mb-3">${p.flavor}</div>
          <div class="text-[10px] text-slate-500 tracking-wider uppercase">Sources</div>
          <div class="text-[11px] text-slate-400 font-mono">[${p.sources.join(', ')}]</div>
        </div>`;
    }
    if (kind === 'subclass') {
      return `
        <div class="rounded-lg border bg-slate-950/95 p-3 shadow-2xl text-left w-64" style="${borderStyle}">
          <div class="text-sm font-bold mb-1" style="color:${color}">${p.name}</div>
          <div class="text-xs italic text-slate-300 mb-2">${p.tagline}</div>
          <div class="text-[10px] text-slate-500 tracking-wider uppercase">Sources</div>
          <div class="text-[11px] text-slate-400 font-mono">[${p.sources.join(', ')}]</div>
        </div>`;
    }
    const max = p.max ?? 10;
    return `
      <div class="rounded-lg border bg-slate-950/95 p-3 shadow-2xl text-left w-64" style="${borderStyle}">
        <div class="flex items-baseline justify-between mb-1.5">
          <div class="text-sm font-bold text-white">${p.name}</div>
          <div class="text-[10px] font-mono" style="color:${color}">${p.level}/${max}</div>
        </div>
        <div class="text-xs text-slate-300 mb-2">${p.note}</div>
        <div class="text-[10px] text-slate-500 tracking-wider uppercase">Sources</div>
        <div class="text-[11px] text-slate-400 font-mono">[${p.sources.join(', ')}]</div>
      </div>`;
  }

  function position(targetRect: DOMRect): void {
    const tipRect = tip.getBoundingClientRect();
    const vw = document.documentElement.clientWidth;
    const vh = document.documentElement.clientHeight;
    const margin = 12;
    let left = targetRect.left + targetRect.width / 2 - tipRect.width / 2;
    left = Math.max(margin, Math.min(vw - tipRect.width - margin, left));
    let top = targetRect.top - tipRect.height - 14;
    if (top < margin) top = targetRect.bottom + 14;
    if (top + tipRect.height > vh - margin) top = vh - tipRect.height - margin;
    tip.style.left = `${left}px`;
    tip.style.top = `${top}px`;
  }

  // ---- Cross-class arc renderer ----
  const crossLinks: { from: string; to: string; label: string }[] = JSON.parse(
    document.getElementById('cross-link-data')?.textContent ?? '[]'
  );
  const arcSvg = document.getElementById('cross-arcs') as SVGSVGElement | null;
  const treeWrap = document.querySelector<HTMLElement>('.tree-wrap');

  function clearArcs(): void {
    if (!arcSvg) return;
    const defs = arcSvg.querySelector('defs');
    while (arcSvg.lastChild && arcSvg.lastChild !== defs) {
      arcSvg.removeChild(arcSvg.lastChild);
    }
  }

  function sizeArcSvg(): void {
    if (!arcSvg || !treeWrap) return;
    const wrapRect = treeWrap.getBoundingClientRect();
    arcSvg.setAttribute('viewBox', `0 0 ${wrapRect.width} ${wrapRect.height}`);
    arcSvg.setAttribute('width', String(wrapRect.width));
    arcSvg.setAttribute('height', String(wrapRect.height));
  }

  // Draw a single arc on demand (hover) connecting two trait cards.
  function drawArcFor(fromId: string, toId: string): void {
    if (!arcSvg || !treeWrap) return;
    if (window.innerWidth < 1024) return;
    sizeArcSvg();
    clearArcs();

    const wrapRect = treeWrap.getBoundingClientRect();
    const a = document.querySelector<HTMLElement>(`[data-trait-id="${fromId}"]`);
    const b = document.querySelector<HTMLElement>(`[data-trait-id="${toId}"]`);
    if (!a || !b) return;
    const ar = a.getBoundingClientRect();
    const br = b.getBoundingClientRect();
    const goingRight = br.left > ar.left;
    const ax = (goingRight ? ar.right : ar.left) - wrapRect.left;
    const ay = ar.top + ar.height / 2 - wrapRect.top;
    const bx = (goingRight ? br.left : br.right) - wrapRect.left;
    const by = br.top + br.height / 2 - wrapRect.top;
    const aClsKey = fromId.split('.')[0];
    const bClsKey = toId.split('.')[0];

    const dx = bx - ax;
    const dist = Math.hypot(dx, by - ay);
    const lift = Math.min(80, 30 + dist * 0.12) * -1;
    const mx = (ax + bx) / 2;
    const my = (ay + by) / 2 + lift;
    const d = `M ${ax} ${ay} Q ${mx} ${my}, ${bx} ${by}`;

    const glow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    glow.setAttribute('d', d);
    glow.setAttribute('fill', 'none');
    glow.setAttribute('stroke', `url(#grad-${aClsKey}-${bClsKey})`);
    glow.setAttribute('stroke-width', '6');
    glow.setAttribute('stroke-linecap', 'round');
    glow.setAttribute('opacity', '0.35');
    glow.setAttribute('filter', 'blur(2.5px)');
    arcSvg.appendChild(glow);

    const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    line.setAttribute('d', d);
    line.setAttribute('fill', 'none');
    line.setAttribute('stroke', `url(#grad-${aClsKey}-${bClsKey})`);
    line.setAttribute('stroke-width', '1.25');
    line.setAttribute('stroke-linecap', 'round');
    line.setAttribute('opacity', '0.95');
    arcSvg.appendChild(line);
  }

  window.addEventListener('resize', sizeArcSvg);
  if (document.fonts?.ready) document.fonts.ready.then(sizeArcSvg);
  setTimeout(sizeArcSvg, 100);

  // ---- Mobile tab nav ----
  const carousel = treeWrap?.querySelector<HTMLElement>(':scope > div.flex');
  const tabs = document.querySelectorAll<HTMLButtonElement>('.class-tab');
  const cols = document.querySelectorAll<HTMLElement>('.class-tree');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-tab-target');
      const target = document.querySelector<HTMLElement>(`.class-tree[data-cls-key="${key}"]`);
      target?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    });
  });
  if (carousel && cols.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        let best: { el: Element; ratio: number } | null = null;
        for (const e of entries) {
          if (!best || e.intersectionRatio > best.ratio) best = { el: e.target, ratio: e.intersectionRatio };
        }
        if (!best) return;
        const key = (best.el as HTMLElement).getAttribute('data-cls-key');
        tabs.forEach((t) => t.classList.toggle('is-active', t.getAttribute('data-tab-target') === key));
      },
      { root: carousel, threshold: [0.3, 0.6, 0.9] }
    );
    cols.forEach((c) => io.observe(c));
    // Initial active
    tabs[0]?.classList.add('is-active');
  }

  // Cross-link map: traitId -> partner traitId
  const crossPartner: Record<string, string> = {};
  for (const link of crossLinks) {
    crossPartner[link.from] = link.to;
    crossPartner[link.to] = link.from;
  }

  document.querySelectorAll<HTMLElement>('.skill-node').forEach((node) => {
    const show = () => {
      const kind = (node.getAttribute('data-tip-kind') as TipKind) ?? 'trait';
      const payload = JSON.parse(node.getAttribute('data-tip') ?? '{}');
      const color = colorFor(node);
      tip.innerHTML = render(kind, payload, color);
      tip.classList.add('show');
      requestAnimationFrame(() => position(node.getBoundingClientRect()));
      // Cross-link partner highlight + draw connecting arc
      const traitId = node.getAttribute('data-trait-id');
      if (traitId && crossPartner[traitId]) {
        const partnerId = crossPartner[traitId];
        const partner = document.querySelector<HTMLElement>(`[data-trait-id="${partnerId}"]`);
        partner?.classList.add('is-cross-target');
        drawArcFor(traitId, partnerId);
      }
    };
    const hide = () => {
      tip.classList.remove('show');
      document.querySelectorAll('.is-cross-target').forEach((n) => n.classList.remove('is-cross-target'));
      clearArcs();
    };
    node.addEventListener('mouseenter', show);
    node.addEventListener('focus', show);
    node.addEventListener('mouseleave', hide);
    node.addEventListener('blur', hide);
  });
</script>
