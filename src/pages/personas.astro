---
import BaseLayout from '../layouts/BaseLayout.astro';

type Trait = { name: string; tier: 'I' | 'II' | 'III'; glyph: string; note: string; sources: number[] };
type Subclass = { name: string; glyph: string; tagline: string; sources: number[]; traits: Trait[] };
type ClassKey = 'builder' | 'craftsman' | 'navigator' | 'strategist';
type BaseClass = {
  key: ClassKey;
  name: string;
  glyph: string;
  tagline: string;
  flavor: string;
  sources: number[];
  subclasses: Subclass[];
};

