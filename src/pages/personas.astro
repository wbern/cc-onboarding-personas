// Investment profile per class — how a "specced" player of that class looks.
// [maxLevel, invested] per tier — some max levels are locked higher tiers,
// invested is what the player has currently spent points on.
// Total invested points per class are visible as the SKILL POINTS spent.
const investment: Record<ClassKey, [number, number][]> = {
  builder:    [[10, 9], [10, 5], [8,  2]],   // front-loaded: tier I maxed, tier III barely opened
  craftsman:  [[10, 7], [10, 7], [10, 8]],   // even deepening across tiers
  navigator:  [[10, 8], [10, 6], [9,  4]],   // strong I, exploring II/III
  strategist: [[10, 4], [10, 6], [10, 9]],   // late-bloomer: tier III nearly maxed
};

function maxFor(classKey: ClassKey, traitIdx: number): number {
  return investment[classKey][traitIdx][0];
}
function curFor(classKey: ClassKey, traitIdx: number): number {
  return investment[classKey][traitIdx][1];
}
function pointsSpent(classKey: ClassKey): number {
  return investment[classKey].reduce((a, [, c]) => a + c, 0);
}
function pointsCap(classKey: ClassKey): number {
  return investment[classKey].reduce((a, [m]) => a + m, 0);
}

// Cross-class skill links — pairs of trait IDs that connect across classes.
// Trait id format: `${classKey}.${subclassIdx}.${traitIdx}` — e.g., "builder.0.0" = Tinkerer/Reverse-engineer.
type CrossLink = { from: string; to: string; label: string };
const crossLinks: CrossLink[] = [
  { from: 'builder.0.0',    to: 'craftsman.0.0',  label: 'Hands-on read' },     // Reverse-engineer ↔ Refactor sight
  { from: 'builder.2.2',    to: 'strategist.1.0', label: 'Find leverage' },     // System bend ↔ Spot bottleneck
  { from: 'craftsman.1.0',  to: 'navigator.1.1',  label: 'Make it teachable' }, // Diff teach ↔ Reframe
  { from: 'navigator.2.0',  to: 'strategist.2.0', label: 'Orchestrate' },       // Delegate ↔ Roadmap
  { from: 'craftsman.2.0',  to: 'strategist.0.2', label: 'Cost discipline' },   // Tool weigh ↔ Surface cost
  { from: 'builder.1.1',    to: 'navigator.1.0',  label: 'Explore the unknown' }, // Generative play ↔ Map terrain
];

