---
import WizardLayout from '../../layouts/WizardLayout.astro';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="Platform Check"
  currentStep={1}
  totalSteps={7}
  prevHref={`${base}`}
  nextHref={null}
>
<div id="page-data" data-base={base} data-next={`${base}builder/terminal`} class="hidden" />
  <h1 class="text-3xl font-bold text-white mb-2">Are you using a Mac?</h1>
  <p class="text-slate-400 mb-8">
    This guide currently supports macOS only. We'll add Windows and Linux soon.
  </p>

  <div class="flex gap-4 mb-8" id="platform-buttons">
    <button
      id="btn-yes"
      class="flex-1 py-4 px-6 rounded-xl border-2 text-lg font-medium
             transition-all duration-300 cursor-pointer
             border-slate-700 bg-slate-800 text-slate-300
             hover:border-indigo-500 hover:text-white"
    >
      Yes
    </button>
    <button
      id="btn-no"
      class="flex-1 py-4 px-6 rounded-xl border-2 text-lg font-medium
             transition-all duration-300 cursor-pointer
             border-slate-700 bg-slate-800 text-slate-300
             hover:border-slate-500 hover:text-white"
    >
      No
    </button>
  </div>

  <div id="not-mac-message" class="hidden text-center p-6 rounded-xl bg-slate-800 border border-slate-700">
    <p class="text-slate-300 text-lg mb-2">
      Hang tight — Windows and Linux support is coming soon.
    </p>
    <p class="text-slate-500 text-sm">
      Check back later or follow us for updates.
    </p>
  </div>
</WizardLayout>

<script>
  const btnYes = document.getElementById('btn-yes')!;
  const btnNo = document.getElementById('btn-no')!;
  const notMacMsg = document.getElementById('not-mac-message')!;
  const pageData = document.getElementById('page-data')!;
  const nextUrl = pageData.dataset.next || '/';

  const isMac = /Mac|macOS/i.test(navigator.userAgent || navigator.platform || '');

  function selectYes() {
    // Visual feedback: highlight Yes, dim No
    btnYes.classList.add('border-indigo-500', 'bg-indigo-500/20', 'text-white', 'scale-105');
    btnNo.classList.add('opacity-40');
    btnNo.classList.remove('hover:border-slate-500', 'hover:text-white');
    notMacMsg.classList.add('hidden');

    // Brief pause for feedback, then navigate
    setTimeout(() => {
      window.location.href = nextUrl;
    }, 400);
  }

  function selectNo() {
    // Visual feedback: highlight No, dim Yes
    btnNo.classList.add('border-red-500/50', 'bg-red-500/10', 'text-white');
    btnYes.classList.add('opacity-40');
    btnYes.classList.remove('hover:border-indigo-500', 'hover:text-white');
    notMacMsg.classList.remove('hidden');
  }

  btnYes.addEventListener('click', selectYes);
  btnNo.addEventListener('click', selectNo);

  // Auto-detect: pre-select but don't auto-navigate
  if (isMac) {
    btnYes.classList.add('border-indigo-500', 'bg-indigo-500/20', 'text-white');
  }
</script>
