---
import WizardLayout from '../../layouts/WizardLayout.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import CopyButton from '../../components/CopyButton.tsx';

const exercisePrompt = 'Build a single-page HTML app with a button that counts clicks';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="Your First Build"
  currentStep={7}
  totalSteps={8}
  prevHref={`${base}builder/login`}
  nextHref={`${base}builder/ready`}
>
  <h1 class="text-3xl font-bold text-white mb-2">Your First Build</h1>
  <p class="text-slate-400 mb-6">
    You're set up. Time to build something real.
  </p>

  <div class="space-y-6">
    <!-- Step 1: Create a project folder -->
    <div>
      <div class="flex items-start gap-3 mb-3">
        <span class="text-indigo-400 mt-0.5 text-lg font-bold">1.</span>
        <p class="text-slate-300">Create a project folder and open Claude Code:</p>
      </div>
      <div class="relative">
        <TerminalMockup command="mkdir my-project && cd my-project && claude" />
        <div class="absolute top-2.5 right-3">
          <CopyButton text="mkdir my-project && cd my-project && claude" client:load />
        </div>
      </div>
    </div>

    <!-- Step 2: Give it a prompt -->
    <div>
      <div class="flex items-start gap-3 mb-3">
        <span class="text-indigo-400 mt-0.5 text-lg font-bold">2.</span>
        <p class="text-slate-300">
          At the <code class="px-1.5 py-0.5 bg-slate-800 rounded text-indigo-400">claude&gt;</code> prompt, type this:
        </p>
      </div>
      <div class="relative">
        <TerminalMockup>
          <div class="text-slate-400">
            <p>
              <span class="text-indigo-400">claude&gt;</span>
              <span class="text-white"> {exercisePrompt}</span>
            </p>
          </div>
        </TerminalMockup>
        <div class="absolute top-2.5 right-3">
          <CopyButton text={exercisePrompt} client:load />
        </div>
      </div>
    </div>

    <!-- Step 3: Watch it build -->
    <div>
      <div class="flex items-start gap-3 mb-3">
        <span class="text-indigo-400 mt-0.5 text-lg font-bold">3.</span>
        <p class="text-slate-300">Watch Claude build it. You'll see something like:</p>
      </div>
      <TerminalMockup>
        <div class="text-slate-400">
          <p class="text-white">I'll create a click counter app for you.</p>
          <p class="mt-2">
            <span class="text-emerald-400">Created</span> index.html
          </p>
          <p class="mt-1 text-slate-500">
            A single-page app with a styled button that tracks
            and displays the click count.
          </p>
        </div>
      </TerminalMockup>
    </div>

    <!-- Step 4: Open the result -->
    <div>
      <div class="flex items-start gap-3 mb-3">
        <span class="text-indigo-400 mt-0.5 text-lg font-bold">4.</span>
        <p class="text-slate-300">Open the file to see your work:</p>
      </div>
      <div class="relative">
        <TerminalMockup command="open index.html" />
        <div class="absolute top-2.5 right-3">
          <CopyButton text="open index.html" client:load />
        </div>
      </div>
    </div>

    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <p class="text-slate-300">
        That's the core workflow: describe what you want, Claude builds it.
        You just shipped your first thing with Claude Code.
      </p>
    </div>
  </div>
</WizardLayout>
