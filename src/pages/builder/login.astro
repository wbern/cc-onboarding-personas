---
import WizardLayout from '../../layouts/WizardLayout.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
---
<WizardLayout
  title="Log In"
  currentStep={6}
  totalSteps={7}
  prevHref="/builder/theme"
  nextHref="/builder/ready"
>
  <h1 class="text-3xl font-bold text-white mb-2">Log In to Your Account</h1>
  <p class="text-slate-400 mb-6">
    Claude Code needs to connect to your Anthropic account. It will open your
    browser automatically.
  </p>

  <div class="space-y-6">
    <TerminalMockup>
      <div class="text-slate-400">
        <p class="text-white">? How would you like to authenticate?</p>
        <p class="text-indigo-400">&gt; Anthropic (claude.ai account)</p>
        <p>&nbsp; Anthropic API Key</p>
        <p>&nbsp; Amazon Bedrock</p>
        <p>&nbsp; Google Vertex AI</p>
      </div>
    </TerminalMockup>

    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <span class="text-indigo-400 mt-0.5 text-lg">1.</span>
          <p class="text-slate-300">
            Press <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-sm text-white">Enter</kbd>
            to select "Anthropic"
          </p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-indigo-400 mt-0.5 text-lg">2.</span>
          <p class="text-slate-300">
            Your browser will open — log in with your Anthropic account
          </p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-indigo-400 mt-0.5 text-lg">3.</span>
          <p class="text-slate-300">
            Come back to the terminal — it will confirm you're logged in
          </p>
        </div>
      </div>
    </div>

    <p class="text-sm text-slate-500">
      You'll need a Claude Pro, Max, Team, or Enterprise subscription.
      If you don't have one yet, you can sign up at
      <span class="text-indigo-400">claude.ai</span>.
    </p>
  </div>
</WizardLayout>
