---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import TerminalMockup from '../../../components/TerminalMockup.astro';
import CopyButton from '../../../components/CopyButton.tsx';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const installCommand = 'curl -fsSL https://claude.ai/install.sh | bash';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'craftsman.install.title')}
  currentStep={3}
  totalSteps={6}
  prevHref={`${base}sv/craftsman/platform`}
  nextHref={`${base}sv/craftsman/login`}
  backLabel={t(locale, 'nav.back')}
  nextLabel={t(locale, 'nav.next')}
  stepLabel={t(locale, 'nav.stepOf').replace('{current}', '3').replace('{total}', '6')}
  lang={locale}
>
  <h1 class="text-3xl font-bold text-white mb-2">{t(locale, 'craftsman.install.title')}</h1>
  <p class="text-slate-400 mb-6">
    {t(locale, 'craftsman.install.subtitle')}
  </p>

  <div class="relative mb-6">
    <TerminalMockup command={installCommand} />
    <div class="absolute top-2.5 right-3">
      <CopyButton text={installCommand} copyLabel={t(locale, 'copy.button')} copiedLabel={t(locale, 'copy.copied')} fallbackLabel={t(locale, 'copy.fallback')} client:load />
    </div>
  </div>

  <div class="space-y-3">
    <TerminalMockup
      command={installCommand}
      output={t(locale, 'run.installOutput')}
    />

    <p class="text-sm text-slate-500">
      {t(locale, 'craftsman.install.description')}
    </p>
  </div>
</WizardLayout>
