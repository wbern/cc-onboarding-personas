---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import TerminalMockup from '../../../components/TerminalMockup.astro';
import CopyButton from '../../../components/CopyButton.tsx';
import { t } from '../../../i18n/translations';

const locale = 'sv';

const buggyCode = `// task_queue.py — a priority task queue with a subtle bug
import threading
import heapq
import time

class TaskQueue:
    def __init__(self, max_retries=3):
        self.heap = []
        self.lock = threading.Lock()
        self.counter = 0
        self.max_retries = max_retries
        self.completed = []

    def push(self, priority, task):
        with self.lock:
            heapq.heappush(self.heap, (priority, self.counter, task))
            self.counter += 1

    def pop(self):
        with self.lock:
            if not self.heap:
                return None
            return heapq.heappop(self.heap)[2]

    def process_with_retry(self, task):
        """Retry a failed task with exponentially increasing priority."""
        attempts = 0
        while attempts < self.max_retries:
            try:
                result = task["fn"]()
                self.completed.append({"task": task["name"], "result": result})
                return result
            except Exception:
                attempts += 1
                new_priority = task["priority"] + (2 ** attempts)
                self.push(new_priority, task)
                time.sleep(0.01 * attempts)
        return None

    def drain(self):
        """Process all tasks until the queue is empty."""
        results = []
        while True:
            task = self.pop()
            if task is None:
                break
            result = self.process_with_retry(task)
            if result is not None:
                results.append(result)
        return results`;

const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'craftsman.exercise.title')}
  currentStep={5}
  totalSteps={6}
  prevHref={`${base}sv/craftsman/login`}
  nextHref={`${base}sv/craftsman/verify`}
  backLabel={t(locale, 'nav.back')}
  nextLabel={t(locale, 'nav.next')}
  stepLabel={t(locale, 'nav.stepOf').replace('{current}', '5').replace('{total}', '6')}
  lang={locale}
>
  <h1 class="text-3xl font-bold text-white mb-2">{t(locale, 'craftsman.exercise.title')}</h1>
  <p class="text-slate-400 mb-6">
    {t(locale, 'craftsman.exercise.subtitle')}
  </p>

  <div class="space-y-6">
    <!-- The buggy code -->
    <div class="relative">
      <TerminalMockup>
        <pre class="text-slate-300 text-xs leading-relaxed overflow-x-auto"><code>{buggyCode}</code></pre>
      </TerminalMockup>
      <div class="absolute top-2.5 right-3">
        <CopyButton
          text={buggyCode}
          copyLabel={t(locale, 'copy.button')}
          copiedLabel={t(locale, 'copy.copied')}
          fallbackLabel={t(locale, 'copy.fallback')}
          client:load
        />
      </div>
    </div>

    <!-- Instructions -->
    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'craftsman.exercise.heading')}</h2>
      <ol class="space-y-3 text-sm text-slate-300">
        <li class="flex items-start gap-3">
          <span class="text-amber-400 shrink-0 font-mono">1.</span>
          <span>{t(locale, 'craftsman.exercise.step1prefix')}
            <code class="px-1.5 py-0.5 bg-slate-800 rounded text-slate-300">task_queue.py</code>
          </span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-amber-400 shrink-0 font-mono">2.</span>
          <span>{t(locale, 'craftsman.exercise.step2prefix')}
            <code class="block mt-1 px-2 py-1 bg-slate-800 rounded text-amber-300">
              find the bugs in task_queue.py and explain each one
            </code>
          </span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-amber-400 shrink-0 font-mono">3.</span>
          <span>{t(locale, 'craftsman.exercise.step3')}</span>
        </li>
      </ol>
    </div>

    <!-- What to expect -->
    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'craftsman.exercise.expectTitle')}</h2>
      <p class="text-slate-400 text-sm mb-3">
        {t(locale, 'craftsman.exercise.expectBody')}
      </p>
      <TerminalMockup>
        <div class="text-slate-400 space-y-1 text-xs">
          <p><span class="text-indigo-400">claude&gt;</span> <span class="text-white">find the bugs in task_queue.py and explain each one</span></p>
          <p class="mt-2"><span class="text-slate-500">Läser</span> task_queue.py</p>
          <p class="mt-2 text-white">Jag hittade två buggar i den här koden:</p>
          <p class="mt-1"><span class="text-amber-400">Bugg 1:</span> <span class="text-slate-300">Oändlig retry-loop i drain()...</span></p>
          <p><span class="text-amber-400">Bugg 2:</span> <span class="text-slate-300">Kapplöpningsproblem på self.completed...</span></p>
          <p class="mt-2 text-slate-500">Vill du att jag fixar dessa? <span class="text-white">[y/n]</span></p>
        </div>
      </TerminalMockup>
      <p class="text-slate-500 text-xs mt-3">
        {t(locale, 'craftsman.exercise.expectFooter')}
      </p>
    </div>

    <!-- Time comparison -->
    <div class="grid grid-cols-2 gap-4" id="time-comparison">
      <div class="p-4 rounded-xl bg-slate-800/50 border border-slate-700 text-center">
        <p class="text-sm text-slate-500 mb-1">{t(locale, 'craftsman.exercise.manualReview')}</p>
        <p class="text-2xl font-bold text-slate-300" id="time-manual">~10 min</p>
        <p class="text-xs text-slate-600 mt-1">{t(locale, 'craftsman.exercise.manualDetail')}</p>
      </div>
      <div class="p-4 rounded-xl bg-amber-500/10 border border-amber-500/20 text-center">
        <p class="text-sm text-amber-400 mb-1">Claude Code</p>
        <p class="text-2xl font-bold text-white" id="time-claude">~15 sek</p>
        <p class="text-xs text-slate-400 mt-1">{t(locale, 'craftsman.exercise.claudeDetail')}</p>
      </div>
    </div>
    <p class="text-xs text-slate-500 -mt-4">
      {t(locale, 'craftsman.exercise.timeNote')}
    </p>

    <!-- Hints (collapsed) -->
    <details class="rounded-xl bg-slate-800/30 border border-slate-700">
      <summary class="cursor-pointer px-5 py-3 text-sm text-slate-400 hover:text-slate-300">
        {t(locale, 'craftsman.exercise.hintsLabel')}
      </summary>
      <div class="px-5 pb-4 space-y-3 text-sm text-slate-400">
        <div>
          <p class="text-white font-medium">{t(locale, 'craftsman.exercise.bug1Title')}</p>
          <p>{t(locale, 'craftsman.exercise.bug1Body')}</p>
        </div>
        <div>
          <p class="text-white font-medium">{t(locale, 'craftsman.exercise.bug2Title')}</p>
          <p>{t(locale, 'craftsman.exercise.bug2Body')}</p>
        </div>
      </div>
    </details>

    <p class="text-sm text-slate-500">
      {t(locale, 'craftsman.exercise.closingNote')}
    </p>
  </div>
</WizardLayout>
