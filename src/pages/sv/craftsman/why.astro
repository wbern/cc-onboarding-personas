---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import TerminalMockup from '../../../components/TerminalMockup.astro';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'craftsman.why.title')}
  currentStep={1}
  totalSteps={3}
  prevHref={`${base}sv/`}
  nextHref={`${base}sv/craftsman/exercise`}
  nextLabel={t(locale, 'nav.next')}
  backLabel={t(locale, 'nav.back')}
  stepLabel={t(locale, 'nav.stepOf').replace('{current}', '1').replace('{total}', '3')}
  lang={locale}
>
  <h1 class="text-3xl font-bold text-white mb-2">{t(locale, 'craftsman.why.title')}</h1>
  <p class="text-slate-400 mb-8">
    {t(locale, 'craftsman.why.subtitle')}
  </p>

  <div class="space-y-8">
    <!-- What CC actually does -->
    <div>
      <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'craftsman.why.hoodTitle')}</h2>
      <p class="text-slate-400 text-sm mb-4">
        {t(locale, 'craftsman.why.hoodBody')}
      </p>
      <TerminalMockup command="claude 'hitta buggen i src/cache.ts'">
        <div class="text-slate-400 mt-1 space-y-2">
          <p><span class="text-slate-500">Läser</span> src/cache.ts</p>
          <p><span class="text-slate-500">Läser</span> src/cache.test.ts</p>
          <p><span class="text-slate-500">Läser</span> src/types.ts</p>
          <p class="mt-2 text-white">Hittade problemet. TTL-jämförelsen på rad 47 använder
<span class="text-amber-400">&lt;</span> istället för <span class="text-amber-400">&lt;=</span>,
vilket gör att poster upphör en sekund för tidigt under
hög skrivkonkurrens.</p>
          <p class="mt-2 text-slate-500">Föreslagen fix:</p>
          <p class="text-red-400">- if (entry.expiresAt &lt; now) {'{'}</p>
          <p class="text-emerald-400">+ if (entry.expiresAt &lt;= now) {'{'}</p>
          <p class="mt-2 text-slate-500">Tillämpa ändringen? <span class="text-white">[y/n]</span></p>
        </div>
      </TerminalMockup>
    </div>

    <!-- Transparency -->
    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'craftsman.why.verifyTitle')}</h2>
      <ul class="space-y-3 text-sm text-slate-300">
        <li class="flex items-start gap-3">
          <span class="text-amber-400 shrink-0 mt-0.5">1.</span>
          <span>{t(locale, 'craftsman.why.verify1')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-amber-400 shrink-0 mt-0.5">2.</span>
          <span>{t(locale, 'craftsman.why.verify2')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-amber-400 shrink-0 mt-0.5">3.</span>
          <span>{t(locale, 'craftsman.why.verify3')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-amber-400 shrink-0 mt-0.5">4.</span>
          <span>{t(locale, 'craftsman.why.verify4')}</span>
        </li>
      </ul>
    </div>

    <!-- Honest limitations -->
    <div class="p-5 rounded-xl bg-amber-500/5 border border-amber-500/20">
      <h2 class="text-lg font-semibold text-amber-300 mb-2">{t(locale, 'craftsman.why.limitsTitle')}</h2>
      <p class="text-slate-400 text-sm">
        {t(locale, 'craftsman.why.limitsBody')}
      </p>
    </div>
  </div>
</WizardLayout>
