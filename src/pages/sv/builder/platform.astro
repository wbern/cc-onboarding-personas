---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'platform.title')}
  currentStep={1}
  totalSteps={7}
  prevHref={`${base}sv/`}
  nextHref={null}
  stepLabel={`Steg 1 av 7`}
  backLabel={t(locale, 'nav.back')}
  nextLabel={t(locale, 'nav.next')}
  lang={locale}
>
<div id="page-data" data-base={base} data-locale={locale} class="hidden" />
  <h1 class="text-3xl font-bold text-white mb-2">{t(locale, 'platform.title')}</h1>
  <p class="text-slate-400 mb-8">{t(locale, 'platform.subtitle')}</p>

  <div class="flex gap-4 mb-8" id="platform-buttons">
    <button id="btn-yes" class="flex-1 py-4 px-6 rounded-xl border-2 text-lg font-medium transition-all duration-200 cursor-pointer border-slate-700 bg-slate-800 text-slate-300 hover:border-indigo-500 hover:text-white">
      {t(locale, 'platform.yes')}
    </button>
    <button id="btn-no" class="flex-1 py-4 px-6 rounded-xl border-2 text-lg font-medium transition-all duration-200 cursor-pointer border-slate-700 bg-slate-800 text-slate-300 hover:border-slate-500 hover:text-white">
      {t(locale, 'platform.no')}
    </button>
  </div>

  <div id="not-mac-message" class="hidden text-center p-6 rounded-xl bg-slate-800 border border-slate-700">
    <p class="text-slate-300 text-lg mb-2">{t(locale, 'platform.notMac')}</p>
    <p class="text-slate-500 text-sm">{t(locale, 'platform.notMacSub')}</p>
  </div>
</WizardLayout>

<script>
  const btnYes = document.getElementById('btn-yes')!;
  const btnNo = document.getElementById('btn-no')!;
  const notMacMsg = document.getElementById('not-mac-message')!;
  const pageData = document.getElementById('page-data')!;
  const selectedClass = ['border-indigo-500', 'bg-indigo-500/10', 'text-white'];
  const isMac = /Mac|macOS/i.test(navigator.userAgent || navigator.platform || '');

  function selectYes() {
    btnYes.classList.add(...selectedClass);
    btnNo.classList.remove(...selectedClass);
    notMacMsg.classList.add('hidden');
    const nav = document.querySelector('nav');
    if (nav && !document.getElementById('wizard-next')) {
      const base = pageData.dataset.base || '/';
      const link = document.createElement('a');
      link.id = 'wizard-next';
      link.href = `${base}sv/builder/install`;
      link.className = 'inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-white bg-indigo-600 hover:bg-indigo-500 transition-colors font-medium';
      link.innerHTML = 'Nästa <span aria-hidden="true">&rarr;</span>';
      nav.appendChild(link);
    }
  }

  function selectNo() {
    btnNo.classList.add(...selectedClass);
    btnYes.classList.remove(...selectedClass);
    notMacMsg.classList.remove('hidden');
    document.getElementById('wizard-next')?.remove();
  }

  btnYes.addEventListener('click', selectYes);
  btnNo.addEventListener('click', selectNo);
  if (isMac) selectYes();
</script>
