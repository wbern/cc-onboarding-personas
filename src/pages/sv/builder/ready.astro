---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import TerminalMockup from '../../../components/TerminalMockup.astro';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'ready.title')}
  currentStep={8} totalSteps={8}
  prevHref={`${base}sv/builder/exercise`}
  nextHref={null}
  stepLabel="Steg 8 av 8" backLabel={t(locale, 'nav.back')} nextLabel={t(locale, 'nav.next')} lang={locale}
>
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold text-white mb-3">{t(locale, 'ready.title')}</h1>
    <p class="text-xl text-slate-400">{t(locale, 'ready.subtitle')}</p>
  </div>
  <div class="space-y-6">
    <TerminalMockup>
      <div class="text-slate-400">
        <p class="text-emerald-400">{t(locale, 'ready.loggedIn')}</p>
        <p class="mt-2 text-white">{t(locale, 'ready.welcome')}</p>
        <p class="mt-1">{t(locale, 'ready.typeMessage')}</p>
        <p class="mt-3">
          <span class="text-indigo-400">claude&gt;</span>
          <span class="animate-pulse text-white">&#x258C;</span>
        </p>
      </div>
    </TerminalMockup>
    <div class="p-6 rounded-xl bg-gradient-to-br from-indigo-500/10 to-purple-500/10 border border-indigo-500/20">
      <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'ready.whatsNext')}</h2>
      <ul class="space-y-2 text-slate-300 text-sm">
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>{t(locale, 'ready.tip1')}</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>{t(locale, 'ready.tip2')} <code class="px-1 py-0.5 bg-slate-800 rounded">/help</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>{t(locale, 'ready.createA')} <code class="px-1 py-0.5 bg-slate-800 rounded">CLAUDE.md</code>{t(locale, 'ready.tip3')}</span>
        </li>
      </ul>
    </div>
  </div>
</WizardLayout>
