---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import KeyVisual from '../../../components/KeyVisual.tsx';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'terminal.title')}
  currentStep={2} totalSteps={7}
  prevHref={`${base}sv/builder/platform`}
  nextHref={`${base}sv/builder/install`}
  stepLabel="Steg 2 av 7" backLabel={t(locale, 'nav.back')} nextLabel={t(locale, 'nav.next')} lang={locale}
>
  <h1 class="text-3xl font-bold text-white mb-2">{t(locale, 'terminal.title')}</h1>
  <p class="text-slate-400 mb-8">{t(locale, 'terminal.subtitle')}</p>
  <div class="space-y-8">
    <div class="text-center">
      <p class="text-slate-300 mb-4 text-lg">
        {t(locale, 'terminal.pressKeys')}
        <span class="text-slate-500 text-sm block mt-1">{t(locale, 'terminal.orClick')}</span>
      </p>
      <div class="flex justify-center"><KeyVisual client:load /></div>
    </div>
    <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
      <p class="text-slate-300 text-lg mb-2">{t(locale, 'terminal.searchAppears')}</p>
      <p class="text-2xl font-mono text-white font-bold tracking-wide">Terminal</p>
      <p class="text-slate-400 mt-2">
        {t(locale, 'terminal.thenPress')} <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-sm text-white">Enter</kbd>
      </p>
    </div>
  </div>
</WizardLayout>
