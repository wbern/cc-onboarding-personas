---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'strategist.result.title')}
  currentStep={3}
  totalSteps={3}
  prevHref={`${base}sv/strategist/compare`}
  nextHref={null}
  stepLabel={t(locale, 'nav.stepOf').replace('{current}', '3').replace('{total}', '3')}
  backLabel={t(locale, 'nav.back')}
  nextLabel={t(locale, 'nav.next')}
  lang={locale}
>
  <h1 class="text-3xl font-bold text-white mb-2">{t(locale, 'strategist.result.heading')}</h1>
  <p class="text-slate-400 mb-8">
    {t(locale, 'strategist.result.subtitle')}
  </p>

  <div class="space-y-8">
    <!-- Summary stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="p-4 rounded-xl bg-indigo-500/10 border border-indigo-500/30 text-center">
        <p class="text-2xl font-bold text-white">{t(locale, 'strategist.result.stat1')}</p>
        <p class="text-xs text-slate-400 mt-1">{t(locale, 'strategist.result.stat1Detail')}</p>
      </div>
      <div class="p-4 rounded-xl bg-indigo-500/10 border border-indigo-500/30 text-center">
        <p class="text-2xl font-bold text-white">{t(locale, 'strategist.result.stat2')}</p>
        <p class="text-xs text-slate-400 mt-1">{t(locale, 'strategist.result.stat2Detail')}</p>
      </div>
      <div class="p-4 rounded-xl bg-indigo-500/10 border border-indigo-500/30 text-center">
        <p class="text-2xl font-bold text-white">{t(locale, 'strategist.result.stat3')}</p>
        <p class="text-xs text-slate-400 mt-1">{t(locale, 'strategist.result.stat3Detail')}</p>
      </div>
    </div>

    <!-- Pricing -->
    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'strategist.result.costHeading')}</h2>
      <ul class="space-y-2 text-sm">
        <li class="flex items-start gap-2 text-slate-300">
          <span class="text-emerald-400 shrink-0 mt-0.5">&#10003;</span>
          <span><strong class="text-white">{t(locale, 'strategist.result.freeTier')}</strong> — {t(locale, 'strategist.result.freeDescription')}</span>
        </li>
        <li class="flex items-start gap-2 text-slate-300">
          <span class="text-indigo-400 shrink-0 mt-0.5">&#10148;</span>
          <span><strong class="text-white">{t(locale, 'strategist.result.proTier')}</strong> — {t(locale, 'strategist.result.proDescription')}</span>
        </li>
        <li class="flex items-start gap-2 text-slate-300">
          <span class="text-indigo-400 shrink-0 mt-0.5">&#10148;</span>
          <span><strong class="text-white">{t(locale, 'strategist.result.maxTier')}</strong> — {t(locale, 'strategist.result.maxDescription')}</span>
        </li>
      </ul>
      <p class="text-xs text-slate-500 mt-3">
        {t(locale, 'strategist.result.upgradeNote')}
      </p>
    </div>

    <!-- Next steps -->
    <div class="p-6 rounded-xl bg-gradient-to-br from-indigo-500/10 to-purple-500/10 border border-indigo-500/20">
      <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'strategist.result.nextSteps')}</h2>
      <ul class="space-y-2 text-slate-300 text-sm">
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>{t(locale, 'strategist.result.next1')}</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>{t(locale, 'strategist.result.next2')} — <code class="px-1.5 py-0.5 bg-slate-800 rounded text-slate-300">git diff main | claude</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>{t(locale, 'strategist.result.next3')}</span>
        </li>
      </ul>
    </div>

    <!-- Closing -->
    <div class="p-5 rounded-xl bg-slate-800 border border-slate-700">
      <p class="text-slate-300 text-sm">
        {t(locale, 'strategist.result.closing')}
        <code class="px-1.5 py-0.5 bg-slate-700 rounded text-slate-300 text-xs">/help</code>
        listar alla kommandon, och
        <code class="px-1.5 py-0.5 bg-slate-700 rounded text-slate-300 text-xs">CLAUDE.md</code>
        ger Claude kontext om ditt projekt.
      </p>
    </div>
  </div>
</WizardLayout>
