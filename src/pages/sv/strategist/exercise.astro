---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import TerminalMockup from '../../../components/TerminalMockup.astro';
import CopyButton from '../../../components/CopyButton.tsx';
import StrategistSvg from '../../../components/StrategistSvg.astro';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const prompt = 'Sammanfatta den här kodbasen: vad gör den, vilken teknikstack används, och vilka är de viktigaste ingångspunkterna?';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'strategist.exercise.title')}
  currentStep={1}
  totalSteps={3}
  prevHref={null}
  nextHref={`${base}sv/strategist/compare`}
  stepLabel={t(locale, 'nav.stepOf').replace('{current}', '1').replace('{total}', '3')}
  backLabel={t(locale, 'nav.back')}
  nextLabel={t(locale, 'nav.next')}
  lang={locale}
>
  <div class="flex items-center gap-4 mb-6">
    <StrategistSvg class="w-16 h-18 shrink-0" />
    <div>
      <h1 class="text-3xl font-bold text-white mb-1">{t(locale, 'strategist.exercise.title')}</h1>
      <p class="text-slate-400">
        {t(locale, 'strategist.exercise.subtitle')}
      </p>
    </div>
  </div>

  <div class="space-y-6">
    <!-- Step 1: Open terminal in a project -->
    <div>
      <div class="flex items-start gap-3 mb-3">
        <span class="text-indigo-400 mt-0.5 text-lg font-bold">1.</span>
        <p class="text-slate-300">{t(locale, 'strategist.exercise.step1')}</p>
      </div>
      <div class="relative">
        <TerminalMockup command="cd ~/your-project && claude" />
        <div class="absolute top-2.5 right-3">
          <CopyButton
            text="cd ~/your-project && claude"
            copyLabel={t(locale, 'copy.button')}
            copiedLabel={t(locale, 'copy.copied')}
            fallbackLabel={t(locale, 'copy.fallback')}
            client:load
          />
        </div>
      </div>
    </div>

    <!-- Step 2: Paste the prompt -->
    <div>
      <div class="flex items-start gap-3 mb-3">
        <span class="text-indigo-400 mt-0.5 text-lg font-bold">2.</span>
        <p class="text-slate-300">
          {t(locale, 'strategist.exercise.step2Prefix')} <code class="px-1.5 py-0.5 bg-slate-800 rounded text-indigo-400">claude&gt;</code> {t(locale, 'strategist.exercise.step2Suffix')}
        </p>
      </div>
      <div class="relative">
        <TerminalMockup>
          <div class="text-slate-400">
            <p>
              <span class="text-indigo-400">claude&gt;</span>
              <span class="text-white ml-1" id="exercise-prompt">{prompt}</span>
            </p>
          </div>
        </TerminalMockup>
        <div class="absolute top-2.5 right-3">
          <CopyButton
            text={prompt}
            copyLabel={t(locale, 'copy.button')}
            copiedLabel={t(locale, 'copy.copied')}
            fallbackLabel={t(locale, 'copy.fallback')}
            client:load
          />
        </div>
      </div>
    </div>

    <!-- Step 3: See the result -->
    <div>
      <div class="flex items-start gap-3 mb-3">
        <span class="text-indigo-400 mt-0.5 text-lg font-bold">3.</span>
        <p class="text-slate-300">{t(locale, 'strategist.exercise.step3')}</p>
      </div>
      <TerminalMockup>
        <div class="text-slate-400">
          <p class="text-white font-medium">{t(locale, 'strategist.exercise.sampleTitle')}</p>
          <p class="mt-2">Det här är en React + TypeScript e-handelsapp byggd med Next.js 14.</p>
          <p class="mt-1"><span class="text-slate-500">Stack:</span> React 18, TypeScript 5.3, Tailwind CSS, Prisma ORM, PostgreSQL</p>
          <p class="mt-2"><span class="text-slate-500">{t(locale, 'strategist.exercise.entryPoints')}:</span></p>
          <p class="ml-2">src/app/layout.tsx <span class="text-slate-600">— rotlayout</span></p>
          <p class="ml-2">src/app/page.tsx <span class="text-slate-600">— startsida</span></p>
          <p class="ml-2">src/app/api/ <span class="text-slate-600">— 12 API-rutter</span></p>
          <p class="ml-2">prisma/schema.prisma <span class="text-slate-600">— datamodell (8 tabeller)</span></p>
          <p class="mt-2 text-slate-500 text-xs">{t(locale, 'strategist.exercise.analyzed')}</p>
        </div>
      </TerminalMockup>
    </div>

    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <p class="text-slate-300">
        {t(locale, 'strategist.exercise.summary')}
      </p>
    </div>
  </div>
</WizardLayout>
