---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'navigator.welcome.title')}
  currentStep={1} totalSteps={6}
  prevHref={`${base}sv/`}
  nextHref={`${base}sv/navigator/open`}
  stepLabel="Steg 1 av 6" backLabel={t(locale, 'nav.back')} nextLabel="Nu kör vi" lang={locale}
>
  <div class="text-center mb-8">
    <div class="text-5xl mb-4" aria-hidden="true">&#127881;</div>
    <h1 class="text-3xl font-bold text-white mb-3">{t(locale, 'navigator.welcome.title')}</h1>
    <p class="text-lg text-slate-300">{t(locale, 'navigator.welcome.subtitle')}</p>
  </div>

  <div class="p-6 rounded-xl bg-emerald-500/10 border border-emerald-500/20 mb-6">
    <h2 class="text-lg font-semibold text-white mb-2">{t(locale, 'navigator.welcome.planTitle')}</h2>
    <p class="text-slate-300 text-sm">{t(locale, 'navigator.welcome.planBody')}</p>
  </div>

  <p class="text-sm text-slate-400 text-center">{t(locale, 'navigator.welcome.safetyNote')}</p>
</WizardLayout>
