---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import TerminalMockup from '../../../components/TerminalMockup.astro';
import CopyButton from '../../../components/CopyButton.tsx';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const installCommand = 'curl -fsSL https://claude.ai/install.sh | bash';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'navigator.install.title')}
  currentStep={4}
  totalSteps={11}
  prevHref={`${base}sv/navigator/terminal`}
  nextHref={`${base}sv/navigator/run`}
  backLabel={t(locale, 'nav.back')}
  nextLabel={t(locale, 'nav.next')}
  stepLabel={t(locale, 'nav.stepOf').replace('{current}', '4').replace('{total}', '11')}
  lang={locale}
>
  <h1 class="text-3xl font-bold text-white mb-3">{t(locale, 'navigator.install.title')}</h1>
  <p class="text-slate-300 mb-6">
    {t(locale, 'navigator.install.subtitle')}
  </p>

  <div class="relative mb-6">
    <TerminalMockup command={installCommand} />
    <div class="absolute top-2.5 right-3">
      <CopyButton text={installCommand} copyLabel={t(locale, 'copy.button')} copiedLabel={t(locale, 'copy.copied')} fallbackLabel={t(locale, 'copy.fallback')} client:load />
    </div>
  </div>

  <div class="p-5 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
    <p class="text-sm text-slate-300">
      {t(locale, 'navigator.install.safetyNote')}
    </p>
  </div>
</WizardLayout>
