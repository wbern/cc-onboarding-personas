---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import TerminalMockup from '../../../components/TerminalMockup.astro';
import CopyButton from '../../../components/CopyButton.tsx';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const openCommand = 'open index.html';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'navigator.result.title')}
  currentStep={10} totalSteps={11}
  prevHref={`${base}sv/navigator/watch`}
  nextHref={`${base}sv/navigator/celebrate`}
  stepLabel="Steg 10 av 11" backLabel={t(locale, 'nav.back')} nextLabel={t(locale, 'nav.next')} lang={locale}
>
  <h1 class="text-3xl font-bold text-white mb-3">{t(locale, 'navigator.result.title')}</h1>
  <p class="text-slate-300 mb-6">{t(locale, 'navigator.result.subtitle')}</p>

  <p class="text-slate-300 mb-3">
    {t(locale, 'navigator.result.instruction')}
    <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-sm text-white">Enter</kbd>:
  </p>

  <div class="relative mb-6">
    <TerminalMockup command={openCommand} />
    <div class="absolute top-2.5 right-3">
      <CopyButton text={openCommand} copyLabel={t(locale, 'copy.button')} copiedLabel={t(locale, 'copy.copied')} fallbackLabel={t(locale, 'copy.fallback')} client:load />
    </div>
  </div>

  <div class="p-5 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
    <p class="text-sm text-slate-300">
      <strong class="text-white">{t(locale, 'navigator.result.browserNote')}</strong>
    </p>
  </div>

  <div class="mt-4 p-4 rounded-lg bg-slate-800 border border-slate-700">
    <p class="text-sm text-slate-300">
      <strong class="text-amber-400">{t(locale, 'navigator.result.fallback')}</strong>
    </p>
  </div>
</WizardLayout>
