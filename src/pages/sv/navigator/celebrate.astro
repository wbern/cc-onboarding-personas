---
import WizardLayout from '../../../layouts/WizardLayout.astro';
import { t } from '../../../i18n/translations';

const locale = 'sv';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title={t(locale, 'navigator.celebrate.title')}
  currentStep={6} totalSteps={6}
  prevHref={`${base}sv/navigator/result`}
  nextHref={null}
  stepLabel="Steg 6 av 6" backLabel={t(locale, 'nav.back')} lang={locale}
>
  <div class="text-center mb-8">
    <div class="text-5xl mb-4" aria-hidden="true">&#127775;</div>
    <h1 class="text-4xl font-bold text-white mb-3">{t(locale, 'navigator.celebrate.title')}</h1>
    <p class="text-lg text-slate-300">{t(locale, 'navigator.celebrate.subtitle')}</p>
  </div>

  <div class="p-6 rounded-xl bg-gradient-to-br from-emerald-500/10 to-teal-500/10 border border-emerald-500/20 mb-6">
    <h2 class="text-lg font-semibold text-white mb-3">{t(locale, 'navigator.celebrate.moreTitle')}</h2>
    <p class="text-slate-300 text-sm mb-4">{t(locale, 'navigator.celebrate.moreBody')}</p>
    <ul class="space-y-3 text-sm">
      <li class="flex items-start gap-2">
        <span class="text-emerald-400 shrink-0 mt-0.5">&#10148;</span>
        <span class="text-slate-300">"{t(locale, 'navigator.celebrate.idea1')}"</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-emerald-400 shrink-0 mt-0.5">&#10148;</span>
        <span class="text-slate-300">"{t(locale, 'navigator.celebrate.idea2')}"</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-emerald-400 shrink-0 mt-0.5">&#10148;</span>
        <span class="text-slate-300">"{t(locale, 'navigator.celebrate.idea3')}"</span>
      </li>
    </ul>
  </div>

  <div class="p-5 rounded-xl bg-slate-800 border border-slate-700 text-center">
    <p class="text-slate-300 text-sm">{t(locale, 'navigator.celebrate.safetyReminder')}</p>
  </div>
</WizardLayout>
