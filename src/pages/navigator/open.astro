---
import WizardLayout from '../../layouts/WizardLayout.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import CopyButton from '../../components/CopyButton.tsx';

const openCommand = 'claude';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="Open Claude Code"
  currentStep={7}
  totalSteps={11}
  prevHref={`${base}navigator/login`}
  nextHref={`${base}navigator/prompt`}
>
  <h1 class="text-3xl font-bold text-white mb-3">Open Claude Code</h1>
  <p class="text-slate-300 mb-6">
    Open the black window you used to install Claude Code
    (it's called Terminal). Then paste this and press
    <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-sm text-white">Enter</kbd>.
  </p>

  <div class="relative mb-6">
    <TerminalMockup command={openCommand} />
    <div class="absolute top-2.5 right-3">
      <CopyButton text={openCommand} client:load />
    </div>
  </div>

  <div class="p-5 rounded-xl bg-slate-800 border border-slate-700 mb-4">
    <p class="text-sm text-slate-300 mb-3">
      <strong class="text-white">Can't find the black window?</strong>
    </p>
    <ol class="text-sm text-slate-400 space-y-2 list-decimal list-inside">
      <li>
        Press <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-xs text-white">&#8984;</kbd>
        + <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-xs text-white">Space</kbd>
        on your keyboard
      </li>
      <li>
        Type <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-xs text-white">Terminal</kbd>
        and press <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-xs text-white">Enter</kbd>
      </li>
    </ol>
  </div>

  <p class="text-sm text-slate-500">
    You should see Claude Code start up with a welcome message. Once it's
    ready, move to the next step.
  </p>
</WizardLayout>
