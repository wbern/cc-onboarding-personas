---
import WizardLayout from '../../layouts/WizardLayout.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import CopyButton from '../../components/CopyButton.tsx';

const promptText = 'Create a personal webpage about me called index.html. Use a fun, colorful design with a welcome message, an "About Me" section with placeholder text I can edit later, and a "Fun Facts" section with 3 bullet points. Make it look modern and friendly.';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="Your First Request"
  currentStep={3}
  totalSteps={6}
  prevHref={`${base}navigator/open`}
  nextHref={`${base}navigator/watch`}
>
  <h1 class="text-3xl font-bold text-white mb-3">Ask Claude to build your webpage</h1>
  <p class="text-slate-300 mb-6">
    Copy the message below and paste it into Claude Code.
    Then press <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-sm text-white">Enter</kbd>.
  </p>

  <div class="relative mb-6">
    <TerminalMockup>
      <div>
        <span class="text-indigo-400">you&gt;</span>
        <span class="text-slate-200 ml-2">{promptText}</span>
      </div>
    </TerminalMockup>
    <div class="absolute top-2.5 right-3">
      <CopyButton text={promptText} client:load />
    </div>
  </div>

  <div class="p-5 rounded-xl bg-indigo-500/10 border border-indigo-500/20">
    <p class="text-sm text-slate-300">
      <strong class="text-white">That's it — just paste and press Enter.</strong>
      Claude will read your request and start building the webpage for you.
      You don't need to type anything else.
    </p>
  </div>
</WizardLayout>
