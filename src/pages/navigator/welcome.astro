---
import WizardLayout from '../../layouts/WizardLayout.astro';
import NavigatorSvg from '../../components/NavigatorSvg.astro';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="You Did It!"
  currentStep={1}
  totalSteps={11}
  prevHref={`${base}`}
  nextHref={`${base}navigator/platform`}
  nextLabel="Let's go"
>
  <div class="text-center mb-8">
    <div class="flex justify-center mb-4">
      <NavigatorSvg class="w-20 h-24" />
    </div>
    <h1 class="text-3xl font-bold text-white mb-3">Welcome!</h1>
    <p class="text-lg text-slate-300">
      We're going to install Claude Code together, step by step.
      Everything is copy-and-paste &mdash; no experience needed.
    </p>
  </div>

  <div class="p-6 rounded-xl bg-emerald-500/10 border border-emerald-500/20 mb-6">
    <h2 class="text-lg font-semibold text-white mb-2">Here's what we'll do together</h2>
    <p class="text-slate-300 text-sm">
      First, we'll install Claude Code on your computer. Then you'll
      ask Claude to build you a personal webpage &mdash; with zero coding.
      The whole thing takes about five minutes.
    </p>
  </div>

  <p class="text-sm text-slate-400 text-center">
    Every step is copy-and-paste. You can close this window at any time
    &mdash; nothing will break.
  </p>
</WizardLayout>
