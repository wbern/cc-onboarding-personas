---
import WizardLayout from '../../layouts/WizardLayout.astro';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="You Did It!"
  currentStep={1}
  totalSteps={6}
  prevHref={`${base}`}
  nextHref={`${base}navigator/open`}
  nextLabel="Let's go"
>
  <div class="text-center mb-8">
    <div class="text-5xl mb-4" aria-hidden="true">&#127881;</div>
    <h1 class="text-3xl font-bold text-white mb-3">You did it!</h1>
    <p class="text-lg text-slate-300">
      Claude Code is installed on your computer. That was the hardest part
      — everything from here is easy.
    </p>
  </div>

  <div class="p-6 rounded-xl bg-emerald-500/10 border border-emerald-500/20 mb-6">
    <h2 class="text-lg font-semibold text-white mb-2">Here's what we'll do together</h2>
    <p class="text-slate-300 text-sm">
      You're going to ask Claude to build you a personal webpage.
      In about two minutes, you'll have a real webpage you can open in
      your browser — made by you, with zero coding.
    </p>
  </div>

  <p class="text-sm text-slate-400 text-center">
    Every step is copy-and-paste. You can close this window at any time
    — nothing will break.
  </p>
</WizardLayout>
