---
import WizardLayout from '../../layouts/WizardLayout.astro';
import KeyVisual from '../../components/KeyVisual.tsx';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="Open Terminal"
  currentStep={3}
  totalSteps={11}
  prevHref={`${base}navigator/platform`}
  nextHref={`${base}navigator/install`}
>
  <h1 class="text-3xl font-bold text-white mb-3">Open the Terminal app</h1>
  <p class="text-slate-300 mb-8">
    Terminal is a small app on your Mac that lets you type instructions.
    If this looks unfamiliar, that's completely normal.
  </p>

  <div class="space-y-8">
    <div class="text-center">
      <p class="text-slate-300 mb-4 text-lg">
        Press these two keys at the same time
        <span class="text-slate-500 text-sm block mt-1">(or click them here)</span>
      </p>
      <div class="flex justify-center">
        <KeyVisual client:load />
      </div>
    </div>

    <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
      <p class="text-slate-300 text-lg mb-2">
        A search bar will appear. Type:
      </p>
      <p class="text-2xl font-mono text-white font-bold tracking-wide">
        Terminal
      </p>
      <p class="text-slate-400 mt-2">
        Then press <kbd class="px-2 py-0.5 rounded bg-slate-700 border border-slate-600 text-sm text-white">Enter</kbd>
      </p>
    </div>

    <div class="p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-center">
      <p class="text-sm text-slate-300">
        A black window will appear. This is Terminal. Leave it open &mdash;
        we'll use it in the next step.
      </p>
    </div>
  </div>
</WizardLayout>
