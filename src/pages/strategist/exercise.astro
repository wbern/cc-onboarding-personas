---
import WizardLayout from '../../layouts/WizardLayout.astro';
import TerminalMockup from '../../components/TerminalMockup.astro';
import CopyButton from '../../components/CopyButton.tsx';
import StrategistSvg from '../../components/StrategistSvg.astro';

const prompt = 'Summarize this codebase: what does it do, what\'s the tech stack, and what are the main entry points?';
const base = import.meta.env.BASE_URL;
---
<WizardLayout
  title="60-Second ROI Test"
  currentStep={1}
  totalSteps={1}
  prevHref={null}
  nextHref={null}
>
  <div class="flex items-center gap-4 mb-6">
    <StrategistSvg class="w-16 h-18 shrink-0" />
    <div>
      <h1 class="text-3xl font-bold text-white mb-1">60-Second ROI Test</h1>
      <p class="text-slate-400">
        One real task. Measurable result. You decide if it's worth it.
      </p>
    </div>
  </div>

  <div class="space-y-8">
    <!-- The exercise -->
    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <h2 class="text-lg font-semibold text-white mb-2">The exercise</h2>
      <p class="text-slate-300 text-sm mb-3">
        Open your terminal in any project folder and start Claude Code.
        Then paste this prompt:
      </p>
      <div class="relative">
        <TerminalMockup>
          <div class="text-slate-400">
            <div class="flex gap-2">
              <span class="text-emerald-400 select-none">$</span>
              <span class="text-slate-200">claude</span>
            </div>
            <p class="mt-2">
              <span class="text-indigo-400">claude&gt;</span>
              <span class="text-white ml-1" id="exercise-prompt">{prompt}</span>
            </p>
          </div>
        </TerminalMockup>
        <div class="absolute top-2.5 right-3">
          <CopyButton text={prompt} client:load />
        </div>
      </div>
    </div>

    <!-- What you'll see -->
    <div>
      <h2 class="text-lg font-semibold text-white mb-2">What you'll get</h2>
      <p class="text-sm text-slate-500 mb-2">Claude Code reads your project and responds with something like:</p>
      <TerminalMockup>
        <div class="text-slate-400">
          <p class="text-white font-medium">Project Summary</p>
          <p class="mt-2">This is a React + TypeScript e-commerce app using Next.js 14.</p>
          <p class="mt-1"><span class="text-slate-500">Stack:</span> React 18, TypeScript 5.3, Tailwind CSS, Prisma ORM, PostgreSQL</p>
          <p class="mt-2"><span class="text-slate-500">Entry points:</span></p>
          <p class="ml-2">src/app/layout.tsx <span class="text-slate-600">— root layout</span></p>
          <p class="ml-2">src/app/page.tsx <span class="text-slate-600">— home page</span></p>
          <p class="ml-2">src/app/api/ <span class="text-slate-600">— 12 API routes</span></p>
          <p class="ml-2">prisma/schema.prisma <span class="text-slate-600">— data model (8 tables)</span></p>
          <p class="mt-2 text-slate-500 text-xs">Analyzed 147 files in 28 seconds.</p>
        </div>
      </TerminalMockup>
    </div>

    <!-- Time comparison -->
    <div class="grid grid-cols-2 gap-4">
      <div class="p-4 rounded-xl bg-slate-800/50 border border-slate-700 text-center">
        <p class="text-sm text-slate-500 mb-1">Manual approach</p>
        <p class="text-2xl font-bold text-slate-300" id="time-manual">~15 min</p>
        <p class="text-xs text-slate-600 mt-1">Read files, trace imports, take notes</p>
      </div>
      <div class="p-4 rounded-xl bg-indigo-500/10 border border-indigo-500/30 text-center">
        <p class="text-sm text-indigo-400 mb-1">Claude Code</p>
        <p class="text-2xl font-bold text-white" id="time-claude">~30 sec</p>
        <p class="text-xs text-slate-400 mt-1">Paste prompt, get structured answer</p>
      </div>
    </div>

    <!-- Free vs paid -->
    <div class="p-5 rounded-xl bg-slate-800/50 border border-slate-700">
      <h2 class="text-lg font-semibold text-white mb-3">What this costs</h2>
      <ul class="space-y-2 text-sm">
        <li class="flex items-start gap-2 text-slate-300">
          <span class="text-emerald-400 shrink-0 mt-0.5">&#10003;</span>
          <span><strong class="text-white">Free tier</strong> — enough uses daily to evaluate properly</span>
        </li>
        <li class="flex items-start gap-2 text-slate-300">
          <span class="text-indigo-400 shrink-0 mt-0.5">&#10148;</span>
          <span><strong class="text-white">Pro ($20/mo)</strong> — unlimited use, faster model, longer context window</span>
        </li>
        <li class="flex items-start gap-2 text-slate-300">
          <span class="text-indigo-400 shrink-0 mt-0.5">&#10148;</span>
          <span><strong class="text-white">Max ($100/mo or $200/mo)</strong> — more usage, background agents, extended thinking</span>
        </li>
      </ul>
      <p class="text-xs text-slate-500 mt-3">
        You'll know when you need to upgrade — it's when you hit the limit mid-task, not before.
      </p>
    </div>

    <!-- Next steps -->
    <div class="p-6 rounded-xl bg-gradient-to-br from-indigo-500/10 to-purple-500/10 border border-indigo-500/20">
      <h2 class="text-lg font-semibold text-white mb-3">Next steps</h2>
      <ul class="space-y-2 text-slate-300 text-sm">
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>Try the prompt above on your actual project right now</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>Ask Claude Code to do something you'd normally spend 10+ minutes on</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-400 shrink-0">&#10148;</span>
          <span>Bookmark this page or share it with your team</span>
        </li>
      </ul>
    </div>
  </div>
</WizardLayout>
