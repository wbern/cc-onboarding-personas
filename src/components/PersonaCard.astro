---
interface Props {
  name: string;
  tagline: string;
  bullets: string[];
  href: string;
  available?: boolean;
  startLabel?: string;
  comingSoonLabel?: string;
}

const { name, tagline, bullets, href, available = true, startLabel = 'Start your journey', comingSoonLabel = 'Coming soon' } = Astro.props;
---
{available ? (
  <a
    href={href}
    class="group block max-w-sm p-6 rounded-2xl border border-slate-700
           bg-slate-800/50 hover:bg-slate-800 hover:border-indigo-500/50
           transition-all duration-300 hover:shadow-lg hover:shadow-indigo-500/10"
  >
    <div class="flex flex-col items-center text-center">
      <div class="mb-4">
        <slot name="illustration" />
      </div>
      <h2 class="text-xl font-bold text-white mb-1 group-hover:text-indigo-300 transition-colors">
        {name}
      </h2>
      <p class="text-sm text-slate-400 mb-4">{tagline}</p>
      <ul class="text-left space-y-2 text-sm text-slate-300 w-full">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-2">
            <span class="text-indigo-400 mt-0.5 shrink-0">&#10003;</span>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
      <div class="mt-5 text-sm font-medium text-indigo-400 group-hover:text-indigo-300 transition-colors">
        {startLabel} &rarr;
      </div>
    </div>
  </a>
) : (
  <div
    class="block max-w-sm p-6 rounded-2xl border border-slate-800
           bg-slate-800/20 opacity-50 cursor-default"
  >
    <div class="flex flex-col items-center text-center">
      <div class="mb-4">
        <slot name="illustration" />
      </div>
      <h2 class="text-xl font-bold text-slate-500 mb-1">{name}</h2>
      <p class="text-sm text-slate-600">{tagline}</p>
      <div class="mt-4 text-xs text-slate-600 uppercase tracking-wider">{comingSoonLabel}</div>
    </div>
  </div>
)}
