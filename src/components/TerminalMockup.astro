---
interface Props {
  command?: string;
  output?: string;
}

const { command, output } = Astro.props;
---
<div class="rounded-xl overflow-hidden border border-slate-700 bg-[#0c0c0c] font-mono text-sm">
  <!-- Title bar -->
  <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-800 border-b border-slate-700">
    <span class="w-3 h-3 rounded-full bg-red-500/80" />
    <span class="w-3 h-3 rounded-full bg-yellow-500/80" />
    <span class="w-3 h-3 rounded-full bg-green-500/80" />
    <span class="ml-2 text-xs text-slate-500">Terminal</span>
  </div>

  <!-- Terminal body -->
  <div class="p-4 space-y-1">
    {command && (
      <div class="flex gap-2">
        <span class="text-emerald-400 select-none">$</span>
        <span class="text-slate-200">{command}</span>
      </div>
    )}
    {output && (
      <div class="text-slate-400 whitespace-pre-wrap">{output}</div>
    )}
    <slot />
  </div>
</div>
