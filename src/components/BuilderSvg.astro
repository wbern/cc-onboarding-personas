---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 120 140"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class:list={['w-32 h-36', className]}
  aria-label="The Builder — a figure carrying a hammer"
  role="img"
>
  <!-- Head (circle) -->
  <circle cx="52" cy="28" r="16" fill="#818cf8" />

  <!-- Body (rounded trapezoid) -->
  <path
    d="M36 52 C36 48, 68 48, 68 52 L72 110 C72 114, 32 114, 32 110 Z"
    fill="#6366f1"
    rx="4"
  />

  <!-- Hammer handle -->
  <rect x="82" y="20" width="4" height="56" rx="2" fill="#94a3b8" transform="rotate(12, 84, 48)" />

  <!-- Hammer head -->
  <rect x="74" y="12" width="22" height="12" rx="3" fill="#e2e8f0" transform="rotate(12, 85, 18)" />

  <!-- Arm holding hammer -->
  <path
    d="M68 56 Q78 50, 82 42"
    stroke="#6366f1"
    stroke-width="6"
    stroke-linecap="round"
    fill="none"
  />

  <!-- Base/feet (simple rounded rect) -->
  <rect x="34" y="110" width="36" height="8" rx="4" fill="#4f46e5" />
</svg>
