---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 120 140"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class:list={['w-32 h-36', className]}
  aria-label="The Builder — a figure carrying a hammer"
  role="img"
>
  <!-- Head (circle) -->
  <circle cx="48" cy="28" r="16" fill="#818cf8" />

  <!-- Body (rounded trapezoid) -->
  <path
    d="M32 52 C32 48, 64 48, 64 52 L68 110 C68 114, 28 114, 28 110 Z"
    fill="#6366f1"
  />

  <!-- Arm reaching up to hold hammer -->
  <path
    d="M64 58 Q76 46, 80 34"
    stroke="#6366f1"
    stroke-width="7"
    stroke-linecap="round"
    fill="none"
  />

  <!-- Hammer handle -->
  <rect x="78" y="8" width="5" height="48" rx="2.5" fill="#94a3b8" transform="rotate(20, 80, 32)" />

  <!-- Hammer head (chunky block) -->
  <rect x="64" y="-2" width="36" height="18" rx="3" fill="#e2e8f0" transform="rotate(20, 82, 7)" />

  <!-- Base/feet (simple rounded rect) -->
  <rect x="30" y="110" width="36" height="8" rx="4" fill="#4f46e5" />
</svg>
