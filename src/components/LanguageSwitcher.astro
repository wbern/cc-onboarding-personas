---
import type { Locale } from '../i18n/translations';

interface Props {
  currentLocale: Locale;
  currentPath: string;
  base: string;
}

const { currentLocale, currentPath, base } = Astro.props;

// Build the equivalent path in the other language
function switchLocalePath(targetLocale: Locale): string {
  // Strip base and current locale prefix to get the "clean" path
  let clean = currentPath;
  if (clean.startsWith(base)) clean = clean.slice(base.length);
  if (clean.startsWith('sv/')) clean = clean.slice(3);
  if (clean.startsWith('/sv/')) clean = clean.slice(4);

  if (targetLocale === 'en') return `${base}${clean}`;
  return `${base}${targetLocale}/${clean}`;
}
---
<div class="flex items-center gap-1 text-sm">
  <a
    href={switchLocalePath('en')}
    class:list={[
      'px-2 py-1 rounded transition-colors',
      currentLocale === 'en'
        ? 'bg-indigo-600 text-white'
        : 'text-slate-400 hover:text-white hover:bg-slate-700',
    ]}
  >
    EN
  </a>
  <a
    href={switchLocalePath('sv')}
    class:list={[
      'px-2 py-1 rounded transition-colors',
      currentLocale === 'sv'
        ? 'bg-indigo-600 text-white'
        : 'text-slate-400 hover:text-white hover:bg-slate-700',
    ]}
  >
    SV
  </a>
</div>
